# ============================================================
# TimeTravel Agency — Backend .env
# Copier ce fichier en .env à la racine du projet
# ============================================================

# Serveur
PORT=3001
NODE_ENV=production
FRONTEND_URL=http://localhost

# ── Provider IA ──────────────────────────────────────────────
# Valeurs : anthropic | openai | mistral | gemini | ollama
AI_PROVIDER=anthropic

# Clé API (inutile si AI_PROVIDER=ollama)
AI_API_KEY=VOTRE_CLE_ICI

# Modèle (laisser vide = défaut du provider)
# anthropic → claude-haiku-4-5-20251001
# openai    → gpt-4o-mini
# mistral   → mistral-small-latest
# gemini    → gemini-1.5-flash  (quota gratuit)
# ollama    → llama3
AI_MODEL=

# URL Ollama si AI_PROVIDER=ollama
OLLAMA_URL=http://localhost:11434

# ── Rate limiting ────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
CHAT_RATE_LIMIT_MAX=10
