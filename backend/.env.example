# ============================================================
# TimeTravel Agency — .env
# Copier ce fichier en .env et remplir les valeurs
# ============================================================

PORT=3001
NODE_ENV=production
FRONTEND_URL=http://localhost

# ── Provider IA ──────────────────────────────────────────────
# Projet brief : Mistral AI (gratuit pour débuter)
# Créer une clé sur : https://console.mistral.ai/
AI_PROVIDER=mistral
AI_API_KEY=VOTRE_CLE_MISTRAL_ICI

# Modèle Mistral (laisser vide = mistral-small-latest)
# Options : mistral-small-latest | mistral-large-latest | open-mistral-7b
AI_MODEL=

# Autres providers possibles : anthropic | openai | gemini | ollama
# (changer AI_PROVIDER et AI_API_KEY en conséquence)

RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
CHAT_RATE_LIMIT_MAX=10
